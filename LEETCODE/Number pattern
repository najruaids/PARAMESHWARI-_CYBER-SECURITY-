public class Main {
    public static void main(String[] args) {
        int N = 5;

        int mid = N / 2;

        for (int i = 0; i < N; i++) {

            int start;

            if (i <= mid) {
                start = i * N + 1;
            } else {
                start = (N * N) - (i - mid) * N + 1;
            }

            for (int j = 0; j < N; j++) {
                System.out.print(start + j + " ");
            }

            System.out.println();
        }
    }
}
